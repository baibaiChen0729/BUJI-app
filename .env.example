# ══════════════════════════════════════════
# 步集 BUJI · 后端环境变量模板
# 用法：复制为 .env 并填入真实值
# ══════════════════════════════════════════

# 服务端口
PORT=3000

# 环境模式
NODE_ENV=development

# 高德地图 Web服务 API Key
# 申请地址：https://lbs.amap.com/dev/key/app （选 "Web服务"）
# 留空则任务生成走静态降级方案（不接入真实地点）
AMAP_KEY=

# 图片上传目录（相对路径）
UPLOADS_DIR=./data/uploads

# 数据库文件路径
DB_PATH=./data/buji.db
